{
  "gateway": {
    "mode": "local",
    "port": 7860,
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streamMode": "partial"
    }
  },

  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 3
      }
    }
  },

  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },

  "messages": {
    "ackReactionScope": "group-mentions"
  },

  "auth": {
    "profiles": {
      "google:studio": {
        "provider": "google",
        "mode": "token"
      }
    },
    "order": {
      "google": ["google:studio"]
    }
  },

  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "redactSensitive": "tools"
  }
}
