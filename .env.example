# =============================================================================
# OpenClaw HF Spaces — Environment Variables
# =============================================================================
# Copy this file or use it as reference when adding secrets to your
# Hugging Face Space (Settings → Repository secrets).
#
# On HF Spaces, each variable below becomes a repository secret.
# Locally, you can source this file or pass --env-file to docker run.
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# Google AI Studio API key (powers Gemini 2.5 Flash)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Protects the OpenClaw web dashboard from unauthorized access.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
OPENCLAW_GATEWAY_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────────

# Telegram bot token — enables the Telegram channel.
# Create a bot via @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# GitHub personal access token — enables the GitHub skill (issues, PRs, CI).
# Create at: https://github.com/settings/tokens (scope: repo)
GH_TOKEN=

# Brave Search API key — enables the Daily Tech Brief heartbeat task.
# Get one at: https://brave.com/search/api/
BRAVE_API_KEY=

# ── Supabase Persistence (Optional) ──────────────────────────────────────────
# HF Spaces containers are ephemeral — all local data is lost on restart.
# Connect Supabase to persist conversations, agent memory, and workspace files.
#
# 1. Create a free project at: https://supabase.com/dashboard
# 2. Copy the URL and keys from Project Settings → API
# 3. Create a storage bucket named "openclaw-workspace" (or your preferred name)
# 4. Set STORAGE_MODE=supabase to activate

# Set to "supabase" to enable persistent storage; leave as "local" to skip.
STORAGE_MODE=local

# Supabase project URL (e.g. https://xyzcompany.supabase.co)
SUPABASE_URL=

# Supabase anon (public) key — safe for client-side, row-level security applies
SUPABASE_ANON_KEY=

# Supabase service role key — full access, used server-side only
# ⚠ Keep this secret. Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket name for workspace files
SUPABASE_STORAGE_BUCKET=openclaw-workspace
